# ─────────────────────────────────────────────
# FRONTEND (Vite, prefix VITE_)
# ─────────────────────────────────────────────

# Яндекс OAuth Client ID для входа через Яндекс (login:info, login:email)
# Создать на https://oauth.yandex.ru/client/new → "Для авторизации пользователей"
# Callback URI: https://rartiushkov.github.io/yandex_agent/ (prod) / http://localhost:5173 (dev)
VITE_YANDEX_CLIENT_ID=c67a37eae4b04ce0bc5507f02d20f2cb
VITE_YANDEX_REDIRECT_URI=https://rartiushkov.github.io/yandex_agent/
# Оставить пустым чтобы использовать права из настроек OAuth приложения
VITE_YANDEX_SCOPES=

# URL запущенного backend Direct connector
# Локально: http://localhost:8787
# Prod: https://yandex-agent-direct-connector.onrender.com
VITE_DIRECT_API_BASE_URL=http://localhost:8787

# Логин клиента Директа если агентский аккаунт (необязательно)
VITE_DIRECT_CLIENT_LOGIN=

# ─────────────────────────────────────────────
# BACKEND (server/, Node.js)
# ─────────────────────────────────────────────

DIRECT_CONNECTOR_PORT=8787
YANDEX_DIRECT_DEFAULT_MODE=sandbox
YANDEX_DIRECT_READ_ONLY=true
YANDEX_DIRECT_CLIENT_LOGIN=

# OAuth приложения Яндекс.Директ — SANDBOX
# Создать на https://oauth.yandex.ru/client/new → "Для доступа к API или отладки"
# Права: direct:api  |  Среда: sandbox
YANDEX_DIRECT_OAUTH_CLIENT_ID_SANDBOX=
YANDEX_DIRECT_OAUTH_CLIENT_SECRET_SANDBOX=

# OAuth приложения Яндекс.Директ — PRODUCTION
# Те же шаги, но отдельное приложение для боевой среды
YANDEX_DIRECT_OAUTH_CLIENT_ID_PRODUCTION=
YANDEX_DIRECT_OAUTH_CLIENT_SECRET_PRODUCTION=

# Master token (опционально — для работы агента без OAuth пользователя)
YANDEX_DIRECT_MASTER_TOKEN_SANDBOX=
YANDEX_DIRECT_MASTER_TOKEN_PRODUCTION=
